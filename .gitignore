# Keep Maven wrapper scripts and wrapper config in repo
!mvnw
!mvnw.cmd

# Ignore everything in .mvn but keep wrapper and jvm config
.mvn/*
!.mvn/wrapper/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
!.mvn/jvm.config

# Ignore help files
